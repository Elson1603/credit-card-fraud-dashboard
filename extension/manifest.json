{
  "manifest_version": 3,
  "name": "Fraud Shield Payment Guard",
  "version": "1.0.0",
  "description": "Dashboard-themed payment risk check extension.",
  "action": {
    "default_title": "Fraud Shield",
    "default_popup": "popup.html"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*"
  ]
}
